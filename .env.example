# Real search adapters (optional — falls back to MockAgent without)
TAVILY_API_KEY=tvly-...      # https://app.tavily.com — WEB_SEARCH slot; generic web search
BRAVE_API_KEY=BSA...         # https://api.search.brave.com — NEWS slot; hits /res/v1/news/search (not web)
EXA_API_KEY=...              # https://exa.ai — SCHOLAR slot; filters to category="research paper"

# Langfuse tracing (optional — falls back to no-op without)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com  # or self-hosted

# Inngest durable workflow (optional — default path uses hand-rolled WorkflowEngine)
# Start the dev server with: npx inngest-cli@latest dev
# Then run: uv run research --use-inngest "your question"
# No cloud account required for local development.
INNGEST_DEV_SERVER_URL=http://localhost:8288
INNGEST_ENV=dev  # set to "production" when deploying to cloud
